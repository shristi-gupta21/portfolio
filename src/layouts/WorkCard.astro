---
import Tag from "./Tag.astro";
const { imgSrc, heading, content, href, color, tags } = Astro.props;

let border = "";
switch (color) {
  case "green":
    border = "border-green-200";
    break;
  case "blue":
    border = "border-blue-350";
    break;
  case "gray":
    border = "border-gray-300";
    break;
  case "purple":
    border = "border-purple-400";
    break;
  case "orange":
    border = "border-orange-200";
    break;
  case "indigo":
    border = "border-indigo-500";
    break;
  default:
    border = "border-gray-200";
}
---

<div
  class=`flex flex-col w-auto h-full  border-4  ${border}  p-1 rounded-lg shadow-gd-sm`
>
  <div class="w-full flex item-center">
    <img
      src={"../projects/" + imgSrc}
      class="h-32 md:h-48 w-full object-contain md:object-cover"
    />
  </div>
  <div class="w-full pt-4 md:pr-4 px-2">
    <div class="flex flex-wrap gap-x-2 gap-y-2 md:gap-y-0">
      {tags?.map((tag) => <Tag title={tag} color={color} />)}
    </div>
    <div class="pt-2 md:pt-3 md:pb-2">
      <a
        href={href}
        target="_blank"
        class="hover:border-b-2 hover:border-b-black hover:transition hover:duration-700 cursor-pointer font-bold text-base md:text-2xl"
      >
        {heading}
      </a>
      <span
        class="text-sm text-gd-gray-300 min-h-[2.5rem] md:text-black line-clamp-2 pt-2"
        >{content}</span
      >
    </div>
    <div class="flex items-end justify-end mt-2 md:mt-0">
      <button>
        <a
          href={href}
          target="_blank"
          class="flex w-fit items-center h-10 rounded px-2 text-sm font-bold text-black hover:transition hover:duration-700 cursor-pointer hover:bg-stone-200 lg:py-1.5 lg:text-base"
        >
          <p
            class="hover:border-b-2 hover:border-b-black hover:transition hover:duration-700"
          >
            Know More
          </p>
          <img src="../icons/caret-right.svg" class="pl-2" />
        </a>
      </button>
    </div>
  </div>
</div>
