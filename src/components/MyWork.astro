---
import WorkCard from "../layouts/WorkCard.astro";
---

<section class="max-w-6xl pt-20 mx-auto">
  <h1 class="text-3xl md:text-6xl font-bold text-center">My Work</h1>
  <div
    class="py-12 grid md:grid-cols-2 gap-4 md:gap-9 max-w-6xl mx-auto px-4 xl:px-0"
  >
    <WorkCard
      heading="GyanDhan Website"
      imgSrc="../images/gyandhan-home.png"
      content="Developed a dynamic and responsive website for Gyandhan, a leading company in education loans, showcasing their services and enhancing their online presence. The project utilized modern web development technologies, including Figma for design, Tailwind CSS for styling, JavaScript for interactivity, HTML for markup, CSS for styling, and Ruby on Rails."
      href="https://astro-gyandhan.vercel.app/"
      border="border-[#81C042]"
    />
    <WorkCard
      heading="To do Web application"
      imgSrc="../images/todo-list.png"
      content="Built a stylish and efficient to-do list using React, Tailwind CSS, and Material-UI, illustrating a knack for creating visually appealing and responsive web applications."
      href="https://tick-task-1.vercel.app/"
      border="border-[#5e0087]"
    />
    <WorkCard
      heading="Online parking Application"
      imgSrc="../images/online-parking.png"
      content="An intuitive online parking app, crafted with React, Redux, and CSS, simplifying parking spot booking and management."
      href="https://online-parking.vercel.app/"
      border="border-blue-350"
    />
    <WorkCard
      heading="Clay Website"
      imgSrc="../images/clay-clone.png"
      content="A Vite-powered React website, styled with Tailwind CSS, that closely mimics the appearance and functionality of an existing site, offering a responsive and streamlined user experience."
      href="https://clay-clone.vercel.app/"
      border="border-[#E3763A]"
    />
    <WorkCard
      heading="Text Utility Application"
      imgSrc="../images/text-utility.png"
      content="Simplify text tasks using a responsive React.js text utility application."
      href="https://shristi-gupta21.github.io/TextUtilityApp/"
      border="border-indigo-500"
    />
  </div>
</section>
